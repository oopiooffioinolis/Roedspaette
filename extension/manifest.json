{
  "manifest_version": 3,
  "name": "Rødspætte",
  "version": "1.1.0",
  "description": "Save Danish words and phrases from any page or PDF into Excel vocab sets in your private GitHub repo \u2014 ordnet.dk lookups, free on-device translation, page highlighting, and automatic rollover to numbered files before GitHub's 1 MB limit.",
  "permissions": [
    "contextMenus",
    "storage",
    "notifications",
    "activeTab",
    "scripting",
    "offscreen",
    "alarms"
  ],
  "host_permissions": [
    "https://api.github.com/*",
    "https://ordnet.dk/*",
    "https://gammel.ordnet.dk/*"
  ],
  "optional_host_permissions": [
    "*://*/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "viewer.html",
        "viewer.js",
        "viewer.css",
        "lib/pdfjs/pdf.mjs",
        "lib/pdfjs/pdf.worker.mjs"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "options_page": "options.html",
  "commands": {
    "capture-selection": {
      "suggested_key": {
        "default": "Alt+Shift+D"
      },
      "description": "Save the current selection to the active vocab set"
    },
    "toggle-highlight": {
      "suggested_key": {
        "default": "Alt+Shift+H"
      },
      "description": "Toggle highlighting of known Danish words on this page"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}